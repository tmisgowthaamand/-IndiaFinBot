{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "og:image",
          "value": "/businessmen-hands-white-table-with-documents-drafts.jpg"
        }
      ]
    }
  ]
}
